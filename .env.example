# Django
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (omit to use SQLite)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Embeddings (text-embedding-3-large is multilingual; -small is cheaper/lower-quality)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# Chat LLM
LLM_PROVIDER=openai            # openai | anthropic
LLM_MODEL=gpt-4o               # claude-sonnet-4-6 if LLM_PROVIDER=anthropic

# Provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Retrieval thresholds (cosine similarity)
QA_BANK_THRESHOLD=0.82
RAG_SIMILARITY_THRESHOLD=0.45

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
